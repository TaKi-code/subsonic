# Optional. When set, the "Ask in plain English" search on the Discover page
# uses Claude (Opus 4.7) to interpret natural-language requests into structured
# filters. Without it, the platform falls back to the algorithmic vibe matcher
# and everything still works.
#
# Copy to .env.local and fill in your key:
#   ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=

# Optional. When both are set, signing in syncs the imported crate and saved
# sets across devices via Supabase. Without them, accounts are hidden and the
# app runs fully local (localStorage). Both values are public (anon key is
# browser-safe, protected by row-level security). Find them in your Supabase
# project under Settings → API. Run supabase/schema.sql once in the SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET — server-only. Required for the "Delete account" flow (GDPR).
# Same Supabase project as the URL/anon above. Find it in Supabase under
# Settings → API Keys, labeled "service_role". DO NOT prefix with NEXT_PUBLIC_
# — this key must never reach the browser. Add it in Vercel as a regular env
# var (Production scope).
SUPABASE_SERVICE_ROLE_KEY=
